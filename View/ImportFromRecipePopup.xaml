<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups"
             xmlns:model="clr-namespace:Listly.Model"
             xmlns:vm="clr-namespace:Listly.ViewModel"
             xmlns:converters="clr-namespace:Listly.Converters"
             x:Class="Listly.View.ImportFromRecipePopup"
             x:Name="Root"
             BackgroundColor="#80000000">

    <Border BackgroundColor="{StaticResource Surface}"
            StrokeThickness="0"
            Padding="24"
            Margin="20"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="380"
            StrokeShape="RoundRectangle 20">
        <Border.Shadow>
            <Shadow Brush="Black" Opacity="0.25" Radius="24" Offset="0,8"/>
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">

            <!-- Title -->
            <Label Grid.Row="0"
                   Text="Import from Recipe"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}"
                   HorizontalOptions="Center"/>

            <!-- STATE: EnterUrl -->
            <StackLayout Grid.Row="1"
                         Spacing="12"
                         IsVisible="{Binding State, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=EnterUrl}">

                <Border Stroke="{StaticResource Outline}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        HeightRequest="56">
                    <Entry Text="{Binding Url}"
                           Placeholder="Paste recipe URL here"
                           FontSize="14"
                           Keyboard="Url"
                           VerticalOptions="Center"
                           Margin="16,0"/>
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       FontSize="12"
                       IsVisible="{Binding HasError}"
                       Margin="4,0"/>

                <Button Text="Extract Ingredients"
                        Command="{Binding ExtractCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        HeightRequest="48"
                        CornerRadius="12"
                        FontSize="16"
                        FontAttributes="Bold"/>
            </StackLayout>

            <!-- STATE: Loading -->
            <StackLayout Grid.Row="1"
                         Spacing="16"
                         VerticalOptions="Center"
                         HorizontalOptions="Center"
                         IsVisible="{Binding State, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Loading}">
                <ActivityIndicator IsRunning="True"
                                   Color="{StaticResource Primary}"
                                   WidthRequest="48"
                                   HeightRequest="48"
                                   HorizontalOptions="Center"/>
                <Label Text="Extracting ingredients..."
                       FontSize="15"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       HorizontalOptions="Center"/>
            </StackLayout>

            <!-- STATE: SelectItems -->
            <Grid Grid.Row="1"
                  RowDefinitions="Auto,*"
                  RowSpacing="8"
                  IsVisible="{Binding State, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=SelectItems}">

                <!-- Select All toggle -->
                <HorizontalStackLayout Grid.Row="0" Spacing="8">
                    <HorizontalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleSelectAllCommand}"/>
                    </HorizontalStackLayout.GestureRecognizers>
                    <CheckBox IsChecked="{Binding AllSelected}"
                              Color="{StaticResource Primary}"
                              InputTransparent="True"/>
                    <Label Text="Select All"
                           VerticalOptions="Center"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceVariant}"/>
                </HorizontalStackLayout>

                <!-- Items list -->
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding Items}"
                                MaximumHeightRequest="350">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:ShoppingItemSuggestion">
                            <Grid ColumnDefinitions="Auto,Auto,*,65,55"
                                  ColumnSpacing="6"
                                  Padding="0,4">

                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsSelected}"
                                          Color="{StaticResource Primary}"
                                          VerticalOptions="Center"/>

                                <!-- Category icon picker -->
                                <Border Grid.Column="1"
                                        Stroke="{StaticResource Outline}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        HeightRequest="40"
                                        WidthRequest="44">
                                    <Grid>
                                        <Label Text="{Binding SuggestedCategory, Converter={StaticResource CategoryDisplayToIconConverter}}"
                                               FontSize="20"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               InputTransparent="True"/>
                                        <Picker ItemsSource="{Binding BindingContext.Categories, Source={x:Reference Root}}"
                                                SelectedItem="{Binding SuggestedCategory, Mode=TwoWay}"
                                                Opacity="0"
                                                Title=" "
                                                HorizontalOptions="Fill"
                                                VerticalOptions="Fill"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Stroke="{StaticResource Outline}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        HeightRequest="40">
                                    <Entry Text="{Binding Name, Mode=TwoWay}"
                                           FontSize="14"
                                           TextColor="{StaticResource OnSurface}"
                                           VerticalOptions="Center"
                                           Margin="8,0"/>
                                </Border>

                                <Border Grid.Column="3"
                                        Stroke="{StaticResource Outline}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        HeightRequest="40">
                                    <Entry Text="{Binding Quantity, Mode=TwoWay, Converter={StaticResource NullableDoubleConverter}}"
                                           Placeholder="Qty"
                                           FontSize="14"
                                           Keyboard="Numeric"
                                           TextColor="{StaticResource OnSurface}"
                                           PlaceholderColor="{StaticResource OnSurfaceVariant}"
                                           HorizontalTextAlignment="Center"
                                           VerticalOptions="Center"
                                           Margin="4,0"/>
                                </Border>

                                <Border Grid.Column="4"
                                        Stroke="{StaticResource Outline}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        HeightRequest="40">
                                    <Entry Text="{Binding Unit, Mode=TwoWay}"
                                           Placeholder="Unit"
                                           FontSize="14"
                                           TextColor="{StaticResource OnSurface}"
                                           PlaceholderColor="{StaticResource OnSurfaceVariant}"
                                           HorizontalTextAlignment="Center"
                                           VerticalOptions="Center"
                                           Margin="4,0"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Action Buttons -->
            <FlexLayout Grid.Row="2"
                        JustifyContent="SpaceBetween"
                        Direction="Row">

                <Button Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="{StaticResource SurfaceVariant}"
                        TextColor="{StaticResource OnSurface}"
                        HeightRequest="48"
                        CornerRadius="12"
                        FontSize="16"
                        FlexLayout.Grow="1"/>

                <Button Text="{Binding AddButtonText}"
                        Command="{Binding AddCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        HeightRequest="48"
                        CornerRadius="12"
                        FontSize="16"
                        FontAttributes="Bold"
                        FlexLayout.Grow="1"
                        Margin="16,0,0,0"
                        IsVisible="{Binding State, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=SelectItems}"/>

            </FlexLayout>
        </Grid>
    </Border>
    <mopups:PopupPage.Resources>
        <ResourceDictionary>
            <converters:EnumEqualsConverter x:Key="EnumEqualsConverter"/>
            <converters:CategoryDisplayToIconConverter x:Key="CategoryDisplayToIconConverter"/>
        </ResourceDictionary>
    </mopups:PopupPage.Resources>
</mopups:PopupPage>
<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups"
             x:Class="Listly.View.AddEditShoppingItemPopup"
             xmlns:converters="clr-namespace:Listly.Converters"
             BackgroundColor="#80000000">
    <Border BackgroundColor="{StaticResource Surface}"
            StrokeThickness="0"
            Padding="24"
            Margin="20"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="380"
            StrokeShape="RoundRectangle 20">
        <Border.Shadow>
            <Shadow Brush="Black" Opacity="0.25" Radius="24" Offset="0,8"/>
        </Border.Shadow>

        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
            <!-- Title -->
            <Label Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}"
                   HorizontalOptions="Center"/>

            <!-- Item Name Input -->
            <Border Grid.Row="1"
                    Stroke="{StaticResource Outline}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 12"
                    HeightRequest="56">
                <Entry Text="{Binding Name}"
                       BackgroundColor="Transparent"
                       Placeholder="Item name"
                       FontSize="15"
                       TextColor="{StaticResource OnSurface}"
                       PlaceholderColor="{StaticResource OnSurfaceVariant}"
                       VerticalOptions="Center"
                       Margin="16,0"/>
            </Border>

            <!-- Category Row with AI suggestion indicator -->
            <Border Grid.Row="2"
                    Stroke="{StaticResource Outline}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 12"
                    HeightRequest="56">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Picker x:Name="CategoryPicker"
                            Grid.Column="0"
                            Title="Category"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource OnSurface}"
                            TitleColor="{StaticResource OnSurfaceVariant}"
                            FontSize="14"
                            VerticalOptions="Center"
                            Margin="16,0"/>

                    <!-- ✨ button inside the field, only visible when appropriate -->
                    <Grid Grid.Column="1"
                          IsVisible="{Binding ShowSuggestButton}"
                          VerticalOptions="Center"
                          Margin="0,0,4,0"
                          WidthRequest="36"
                          HeightRequest="36">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SuggestCategoryCommand}"/>
                        </Grid.GestureRecognizers>

                        <!-- Glowing aura behind the sparkle -->
                        <BoxView x:Name="SparkleAura"
                                 WidthRequest="44"
                                 HeightRequest="44"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Opacity="0">
                            <BoxView.Background>
                                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                                    <GradientStop Color="#FFFFD700" Offset="0.0"/>
                                    <GradientStop Color="#00FFD700" Offset="1.0"/>
                                </RadialGradientBrush>
                            </BoxView.Background>
                        </BoxView>

                        <Label x:Name="SparkleLabel"
                               Text="✨"
                               FontSize="18"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
                    </Grid>

                    <!-- Spinner replaces the ✨ button while loading -->
                    <ActivityIndicator Grid.Column="2"
                                       IsRunning="{Binding IsSuggestingCategory}"
                                       IsVisible="{Binding IsSuggestingCategory}"
                                       Color="{StaticResource Primary}"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       VerticalOptions="Center"
                                       Margin="0,0,12,0"/>
                </Grid>
            </Border>

            <Label Grid.Row="3"
                   Text="✨ Tap to auto-suggest a category"
                   FontSize="11"
                   TextColor="{StaticResource OnSurfaceVariant}"
                   IsVisible="{Binding ShowSuggestButton}"
                   Margin="4,-4,0,0"/>

            <HorizontalStackLayout Grid.Row="4" Spacing="10" Margin="5,0">
                <Label Text="Set Priority" 
                       VerticalOptions="Center" 
                       FontSize="15"/>
                    <Switch x:Name="PrioritySwitch"
                            IsToggled="{Binding HasPriority}"
                            OnColor="#2196F3"/>
            </HorizontalStackLayout>

            <Border Grid.Row="5"
                    Stroke="{StaticResource Outline}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 12"
                    HeightRequest="56"
                    IsVisible="{Binding HasPriority}">
                <Picker x:Name="PriorityPicker"
                        Title="Priority"
                        ItemsSource="{Binding Priorities}"
                        SelectedItem="{Binding ItemPriority}"
                        BackgroundColor="White"
                        TextColor="{StaticResource OnSurface}"
                        TitleColor="{StaticResource OnSurfaceVariant}"
                        FontSize="14"
                        VerticalOptions="Center"
                        Margin="16,0"/>
            </Border>

            <!-- Quantity Section -->
            <StackLayout Grid.Row="6" Spacing="12">
                <Label Text="Quantity"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{StaticResource OnSurface}"/>

                <Grid ColumnDefinitions="*,*,56,56" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Stroke="{StaticResource Outline}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="56">
                        <Entry Text="{Binding Quantity, Mode=TwoWay, Converter={StaticResource NullableDoubleConverter}}"
                               Placeholder="Quantity"
                               FontSize="14"
                               TextColor="{StaticResource OnSurface}"
                               PlaceholderColor="{StaticResource OnSurfaceVariant}"
                               VerticalOptions="Center"
                               Margin="10,0"/>
                    </Border>

                    <Border Grid.Column="1"
                            Stroke="{StaticResource Outline}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="56">
                        <Entry Text="{Binding Unit, Mode=TwoWay}"
                               Placeholder="Unit"
                               FontSize="14"
                               TextColor="{StaticResource OnSurface}"
                               PlaceholderColor="{StaticResource OnSurfaceVariant}"
                               VerticalOptions="Center"
                               Margin="10,0"/>
                    </Border>

                    <Button Grid.Column="2"
                            Text="−"
                            Command="{Binding DecreaseQuantityCommand}"
                            BackgroundColor="{StaticResource SurfaceVariant}"
                            TextColor="{StaticResource OnSurface}"
                            WidthRequest="56"
                            HeightRequest="56"
                            CornerRadius="28"
                            FontSize="20"
                            FontAttributes="Bold"/>

                    <Button Grid.Column="3"
                            Text="+"
                            Command="{Binding IncreaseQuantityCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource OnPrimary}"
                            WidthRequest="56"
                            HeightRequest="56"
                            CornerRadius="28"
                            FontSize="20"
                            FontAttributes="Bold"/>
                </Grid>
            </StackLayout>

            <!-- Action Buttons -->
            <Grid Grid.Row="7" ColumnDefinitions="*,*" ColumnSpacing="16">
                <Button Grid.Column="0"
                    Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="{StaticResource SurfaceVariant}"
                    TextColor="{StaticResource OnSurface}"
                    HeightRequest="48"
                    CornerRadius="12"
                    FontSize="16"/>

                <Button Grid.Column="1"
                    Text="Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource OnPrimary}"
                    HeightRequest="48"
                    CornerRadius="12"
                    FontSize="16"
                    FontAttributes="Bold"/>
            </Grid>
        </Grid>
    </Border>
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:NullableDoubleConverter x:Key="NullableDoubleConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
</mopups:PopupPage>